#!/usr/bin/env bash
# ralph — AFK Ralph Wiggum loop. Runs Claude in a Docker sandbox against the
# `ready-for-agent` GitHub issue pool of the current repo until the pool is
# drained or the iteration cap is hit.
#
# Usage:
#   ralph                        # pool drain, default cap (5)
#   ralph --issue 42             # single-issue override, default cap (3)
#   ralph --max-iterations 50    # custom cap
#
# Preconditions:
#   - `sbx` (Docker sandbox CLI) installed
#   - `gh` authenticated for the current repo
#   - Repo has triage labels (ready-for-agent, ready-for-human)
#   - Prompt at $XDG_CONFIG_HOME/ralph/prompt.md (or ~/.config/ralph/prompt.md)

set -euo pipefail

ISSUE=""
MAX_ITERATIONS=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    --issue) ISSUE="$2"; shift 2 ;;
    --max-iterations) MAX_ITERATIONS="$2"; shift 2 ;;
    -h|--help)
      sed -n '2,16p' "$0" | sed 's/^# \?//'
      exit 0
      ;;
    *) echo "ralph: unknown flag: $1" >&2; exit 2 ;;
  esac
done

if [[ -z "$MAX_ITERATIONS" ]]; then
  if [[ -n "$ISSUE" ]]; then
    MAX_ITERATIONS=3
  else
    MAX_ITERATIONS=5
  fi
fi

PROMPT_FILE="${XDG_CONFIG_HOME:-$HOME/.config}/ralph/prompt.md"
if [[ ! -f "$PROMPT_FILE" ]]; then
  echo "ralph: prompt missing at $PROMPT_FILE" >&2
  exit 1
fi

if ! command -v sbx >/dev/null 2>&1; then
  echo "ralph: sbx CLI not found on PATH" >&2
  exit 1
fi

if ! command -v perl >/dev/null 2>&1; then
  echo "ralph: perl not found on PATH (needed to strip ANSI escapes from claude's output)" >&2
  exit 1
fi

if ! git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
  echo "ralph: $PWD is not inside a git repository" >&2
  exit 1
fi

if ! gh auth status >/dev/null 2>&1; then
  echo "ralph: gh is not authenticated (run \`gh auth login\`)" >&2
  exit 1
fi

if ! gh repo view >/dev/null 2>&1; then
  echo "ralph: this git repo has no GitHub remote that gh can resolve" >&2
  exit 1
fi

if [[ ! -d "$HOME/dotfiles/claude/.claude" ]]; then
  echo "ralph: $HOME/dotfiles/claude/.claude not found (ralph expects the dotfiles repo at \$HOME/dotfiles)" >&2
  exit 1
fi

SANDBOX_NAME="$(basename "$PWD")-ralph"
PROMPT="$(cat "$PROMPT_FILE")"

# sbx mounts land at literal host paths and the agent runs as $HOME=/home/agent,
# so Claude can't see the host's ~/.claude/ without surgical symlinks. Mount the
# dotfiles repo read-only and symlink the canonical CLAUDE.md + skills into the
# agent's $HOME on first create.
if ! sbx ls -q | grep -qx "$SANDBOX_NAME"; then
  echo "ralph: bootstrapping sandbox $SANDBOX_NAME"
  sbx create --name "$SANDBOX_NAME" claude . "$HOME/.claude:ro" "$HOME/dotfiles:ro"
  sbx exec "$SANDBOX_NAME" -- bash -c "
    mkdir -p \$HOME/.claude
    ln -sfn $HOME/dotfiles/claude/.claude/CLAUDE.md \$HOME/.claude/CLAUDE.md
    ln -sfn $HOME/dotfiles/claude/.claude/skills    \$HOME/.claude/skills
  "
fi

if [[ -n "$ISSUE" ]]; then
  PROMPT="$PROMPT

---
TARGET ISSUE: #$ISSUE
Skip the pool query. Work directly on this issue."
fi

LOG_DIR="${XDG_STATE_HOME:-$HOME/.local/state}/ralph"
mkdir -p "$LOG_DIR"
LOG="$LOG_DIR/$SANDBOX_NAME.log"
: > "$LOG"

notify() {
  osascript -e "display notification \"$2\" with title \"$1\" sound name \"Glass\"" >/dev/null 2>&1 || true
}

echo "ralph: sandbox=$SANDBOX_NAME mode=$([[ -n $ISSUE ]] && echo "single(#$ISSUE)" || echo "pool-drain") cap=$MAX_ITERATIONS"
echo "ralph: tail with: tail -f $LOG"

# Strip ANSI escape sequences from claude's output before logging — sbx run
# allocates a TTY inside the sandbox, so claude emits a full TUI by default,
# which makes the log unreadable via tail. Handles CSI (ESC [ ...), OSC
# (ESC ] ... BEL/ST), 2-byte ESC sequences, and leftover C0 control bytes.
STRIP_ANSI='BEGIN{$|=1}
  s/\e\[[0-?]*[ -\/]*[@-~]//g;
  s/\e\].*?(?:\x07|\e\\)//gs;
  s/\e.//g;
  s/[\x00-\x08\x0b\x0c\x0e-\x1f\x7f]//g'

for ((i=1; i<=MAX_ITERATIONS; i++)); do
  echo "ralph: iteration $i/$MAX_ITERATIONS"
  printf '\n=== iteration %d/%d at %s ===\n' "$i" "$MAX_ITERATIONS" "$(date -Iseconds)" >> "$LOG"
  if sbx run "$SANDBOX_NAME" -- -p "$PROMPT" 2>&1 | perl -pe "$STRIP_ANSI" >> "$LOG"; then
    if grep -q '<promise>COMPLETE</promise>' "$LOG"; then
      echo "ralph: pool drained at iteration $i"
      notify "ralph" "pool drained after $i iteration(s)"
      exit 0
    fi
  else
    echo "ralph: iteration $i failed (see $LOG)" >&2
  fi
done

echo "ralph: iteration cap ($MAX_ITERATIONS) reached"
notify "ralph" "cap reached ($MAX_ITERATIONS iterations)"
