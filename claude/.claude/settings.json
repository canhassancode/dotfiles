{
  "permissions": {
    "allow": [
      "Read(*)",
      "Edit(~/Obsidian/**)",
      "Glob(*)",
      "Grep(*)",
      "Search(*)",
      "WebSearch(*)",
      "WebFetch(*)",
      "Fetch(https://*)",
      "Bash(pnpm run *)",
      "Bash(pnpm test *)",
      "Bash(pnpm lint *)",
      "Bash(pnpm type-check *)",
      "Bash(npm run *)",
      "Bash(npm test *)",
      "Bash(go run *)",
      "Bash(go test *)",
      "Bash(go build *)",
      "Bash(docker compose *)",
      "Bash(docker ps *)",
      "mcp__claude_ai_Slack__slack_search_users",
      "mcp__claude_ai_Slack__slack_search_channels",
      "mcp__claude_ai_Google_Drive__search_files",
      "mcp__claude_ai_Google_Drive__get_file_metadata"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(git push --force *)",
      "Bash(git reset --hard *)",
      "Bash(git clean -f *)",
      "EnterPlanMode",
      "ExitPlanMode",
      "DesignSync",
      "NotebookEdit",
      "ReportFindings",
      "AskUserQuestion",
      "ScheduleWakeup",
      "CronCreate",
      "CronDelete",
      "CronList"
    ],
    "ask": ["Bash(node *)", "Bash(npx *)", "Bash(curl *)", "Bash(pnpm install *)", "Bash(pnpm exec *)", "Bash(git push *)"],
    "defaultMode": "auto"
  },
  "model": "opus",
  "disableBundledSkills": true,
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|Read|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/guard.sh"
          }
        ]
      },
      {
        "matcher": "mcp__.*__(execute_sql|execute_query|query|explain_query)",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/sql-guard.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/npx-repoint.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/commit-guard.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/pr-guard.sh"
          }
        ]
      }
    ]
  },
  "disableWorkflows": true,
  "disableArtifact": true,
  "statusLine": {
    "type": "command",
    "command": "bash $HOME/.claude/statusline-command.sh"
  },
  "effortLevel": "high",
  "tui": "fullscreen",
  "autoMemoryEnabled": false,
  "theme": "auto"
}
