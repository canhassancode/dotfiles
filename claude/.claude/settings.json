{
  "permissions": {
    "allow": [
      "Read(*)",
      "Edit(/Users/hssn/Obsidian/**)",
      "Write(/Users/hssn/Obsidian/**)",
      "Glob(*)",
      "Grep(*)",
      "Search(*)",
      "WebSearch(*)",
      "WebFetch(*)",
      "Fetch(https://*)",
      "Bash(pnpm run *)",
      "Bash(pnpm test *)",
      "Bash(pnpm lint *)",
      "Bash(pnpm type-check *)",
      "Bash(npm run *)",
      "Bash(npm test *)",
      "Bash(go run *)",
      "Bash(go test *)",
      "Bash(go build *)",
      "Bash(docker compose *)",
      "Bash(docker ps *)",
      "mcp__claude_ai_Notion__notion-fetch",
      "mcp__claude_ai_Notion__notion-search",
      "mcp__claude_ai_Notion__notion-get-users",
      "mcp__claude_ai_Slack__slack_search_users",
      "mcp__claude_ai_Slack__slack_search_channels",
      "mcp__claude_ai_Google_Drive__search_files",
      "mcp__claude_ai_Google_Drive__get_file_metadata"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(git push --force *)",
      "Bash(git reset --hard *)",
      "Bash(git clean -f *)"
    ],
    "ask": [
      "Bash(node *)",
      "Bash(npx *)",
      "Bash(curl *)",
      "Bash(pnpm install *)",
      "Bash(pnpm exec *)",
      "Bash(git push *)"
    ],
    "defaultMode": "auto"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|Read|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/guard.sh"
          }
        ]
      },
      {
        "matcher": "mcp__.*__(execute_sql|execute_query|query|explain_query)",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/sql-guard.sh"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "startup|clear",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/morning-brief-nudge.sh"
          }
        ]
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash '/Users/hssn/.claude/hooks/herdr-agent-state.sh' session",
            "timeout": 10
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash $HOME/.claude/statusline-command.sh"
  },
  "effortLevel": "xhigh"
}
